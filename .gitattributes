# Normalize text files to LF in the repository (cross-platform default).
* text=auto eol=lf

# Source and project files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf
*.targets text eol=lf

# Documentation and config
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.editorconfig text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf
*.txt text eol=lf
*.sql text eol=lf
*.ps1 text eol=lf
*.sh text eol=lf

# Windows scripts should keep CRLF for best compatibility.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.dll binary
*.exe binary
